---
// A boxed, quotable callout that extracts the framework-agnostic design lesson
// from a post. Use once near the end of each post:
//   <DesignPrinciple>One-paragraph lesson here.</DesignPrinciple>
---

<aside class="design-principle">
  <span class="design-principle-eyebrow">Design principle</span>
  <p class="design-principle-body"><slot /></p>
</aside>

<style>
  .design-principle {
    margin: 2.5rem 0;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--border-strong);
    border-left: 4px solid var(--accent);
    border-radius: 6px;
    background: var(--code-bg);
  }
  .design-principle-eyebrow {
    display: block;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .design-principle-body {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.55;
    color: var(--text);
    font-style: italic;
  }
  /* Constrain to prose column like other block elements */
  :global(.prose) > .design-principle {
    max-width: 660px;
  }
</style>
