---
import { url } from '../utils/url';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <span class="copy">© {year} Ashish</span>
    <nav class="footer-nav" aria-label="Footer">
      <a href={url('rss.xml')}>RSS</a>
      <a href="https://github.com/AshishMehtaIO" target="_blank" rel="noopener">GitHub</a>
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
    margin-top: 6rem;
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.85rem;
  }

  .container {
    max-width: var(--content-width-full);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-nav {
    display: flex;
    gap: 1.25rem;
  }

  .footer-nav a {
    color: var(--text-muted);
    text-decoration: none;
  }
  .footer-nav a:hover {
    color: var(--text);
  }
</style>
