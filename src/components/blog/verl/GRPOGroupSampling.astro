---
// Viz 2 — GRPO group sampling. Sliders control group size N and reward spread σ.
// Three rows of bars show, top-to-bottom: raw rewards, centered (r - mean),
// and standardized advantages ((r - mean) / std) — i.e., GRPO step by step.
//
// Pattern: hand-authored inline SVG + per-figure script, vanilla JS.
// Sliders are plain <input type="range"> with event listeners.
---

<figure class="grpo-figure" aria-label="Interactive GRPO group sampling visualization">
  <div class="grpo-board">
    <svg
      viewBox="0 0 720 360"
      role="img"
      preserveAspectRatio="xMidYMid meet"
      class="grpo-svg"
    >
      <!-- Row labels (left) -->
      <text class="row-label" x="14" y="48">raw r<tspan class="sub" dy="3">i</tspan></text>
      <text class="row-label" x="14" y="158">r<tspan class="sub" dy="3">i</tspan><tspan dy="-3"> − μ</tspan></text>
      <text class="row-label" x="14" y="268">Â<tspan class="sub" dy="3">i</tspan></text>

      <!-- Axes (subtle baselines) -->
      <line class="baseline" x1="90" y1="70"  x2="700" y2="70"  />
      <line class="baseline" x1="90" y1="180" x2="700" y2="180" />
      <line class="baseline" x1="90" y1="290" x2="700" y2="290" />

      <!-- Bar containers — populated by JS -->
      <g class="bars bars-raw"      data-row="raw"      transform="translate(90 0)"></g>
      <g class="bars bars-centered" data-row="centered" transform="translate(90 0)"></g>
      <g class="bars bars-adv"      data-row="adv"      transform="translate(90 0)"></g>

      <!-- Stat readouts (right of last row) -->
      <text class="stat-readout" x="700" y="48" text-anchor="end">
        μ = <tspan data-stat="mean">—</tspan>
      </text>
      <text class="stat-readout" x="700" y="158" text-anchor="end">
        σ = <tspan data-stat="std">—</tspan>
      </text>
      <text class="stat-readout" x="700" y="268" text-anchor="end">
        N = <tspan data-stat="n">—</tspan>
      </text>
    </svg>

    <div class="grpo-formula">
      <span>
        Â<sub>i</sub> = ( r<sub>i</sub> − μ ) / σ
      </span>
      <span class="formula-note">
        GRPO uses the group itself as the baseline and the group's std to normalize the scale.
        No critic, no GAE — just statistics of N independent rollouts of the same prompt.
      </span>
    </div>
  </div>

  <div class="grpo-controls">
    <label class="grpo-slider">
      <span class="slider-label">Group size N</span>
      <input type="range" min="2" max="32" step="1" value="8" data-control="n" />
      <output data-readout="n">8</output>
    </label>
    <label class="grpo-slider">
      <span class="slider-label">Reward spread σ<sub>r</sub></span>
      <input type="range" min="0" max="100" step="1" value="40" data-control="spread" />
      <output data-readout="spread">0.40</output>
    </label>
    <button type="button" class="grpo-resample" data-control="resample">Resample</button>
  </div>

  <figcaption>
    Sample N responses to the same prompt, score each one, then compute advantages by subtracting
    the group mean and dividing by the group std. Drag the sliders to see how group size and
    reward spread shape the advantage signal. Negative bars are dark; positive bars are accent.
  </figcaption>
</figure>

<script>
  (function () {
    // Mulberry32 PRNG for reproducible draws within a session.
    function mulberry32(seed: number) {
      return function () {
        let t = (seed += 0x6d2b79f5);
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }
    // Box-Muller to draw from a normal
    function gauss(rng: () => number, mean: number, std: number) {
      let u = 0, v = 0;
      while (u === 0) u = rng();
      while (v === 0) v = rng();
      return mean + std * Math.sqrt(-2.0 * Math.log(u)) * Math.cos(2.0 * Math.PI * v);
    }

    document.querySelectorAll<HTMLElement>('.grpo-figure').forEach((fig) => {
      const svg = fig.querySelector<SVGSVGElement>('.grpo-svg')!;
      const rowRaw = fig.querySelector<SVGGElement>('.bars-raw')!;
      const rowCen = fig.querySelector<SVGGElement>('.bars-centered')!;
      const rowAdv = fig.querySelector<SVGGElement>('.bars-adv')!;
      const inputN = fig.querySelector<HTMLInputElement>('[data-control="n"]')!;
      const inputS = fig.querySelector<HTMLInputElement>('[data-control="spread"]')!;
      const btn    = fig.querySelector<HTMLButtonElement>('[data-control="resample"]')!;
      const outN   = fig.querySelector<HTMLElement>('[data-readout="n"]')!;
      const outS   = fig.querySelector<HTMLElement>('[data-readout="spread"]')!;
      const sMean  = fig.querySelector<SVGTSpanElement>('[data-stat="mean"]')!;
      const sStd   = fig.querySelector<SVGTSpanElement>('[data-stat="std"]')!;
      const sN     = fig.querySelector<SVGTSpanElement>('[data-stat="n"]')!;

      // Bars area is 610px wide (svg 720 minus 90 left margin and 20 right gutter)
      const W = 610;
      const RAW_BASE = 70, CENTER_BASE = 180, ADV_BASE = 290;
      const RAW_H = 60;       // raw bars grow upward from RAW_BASE
      const HALF_H = 50;      // signed bars grow up or down from baseline

      let seed = 12345;

      function render() {
        const N = Math.max(2, Math.min(32, parseInt(inputN.value, 10) || 8));
        const spread = (parseInt(inputS.value, 10) || 40) / 100; // 0..1
        outN.textContent = String(N);
        outS.textContent = spread.toFixed(2);
        sN.textContent = String(N);

        const rng = mulberry32(seed);
        // Generate N rewards from a Beta-ish distribution clamped to [0, 1].
        // Use a Gaussian centered at 0.5 with std = spread, then clamp.
        const r: number[] = [];
        for (let i = 0; i < N; i++) {
          const v = gauss(rng, 0.5, Math.max(0.04, spread * 0.45));
          r.push(Math.max(0, Math.min(1, v)));
        }

        const mean = r.reduce((a, b) => a + b, 0) / N;
        // Population std (matches GRPO convention)
        const variance = r.reduce((a, b) => a + (b - mean) * (b - mean), 0) / N;
        const std = Math.sqrt(variance);
        sMean.textContent = mean.toFixed(2);
        sStd.textContent = std.toFixed(2);

        const barW = Math.max(6, Math.floor(W / N) - 4);
        const stepX = W / N;
        const padX = (stepX - barW) / 2;

        // Clear previous
        rowRaw.replaceChildren();
        rowCen.replaceChildren();
        rowAdv.replaceChildren();

        // Determine scale for centered & advantage rows
        const centered = r.map((v) => v - mean);
        const advs = std > 1e-6 ? centered.map((c) => c / std) : centered.map(() => 0);
        const cenAbsMax = Math.max(0.01, ...centered.map((c) => Math.abs(c)));
        const advAbsMax = Math.max(0.5, ...advs.map((a) => Math.abs(a)));

        const NS = 'http://www.w3.org/2000/svg';

        for (let i = 0; i < N; i++) {
          const x = padX + i * stepX;

          // Raw bar — always positive, grows up from RAW_BASE
          const hRaw = r[i] * RAW_H;
          const rectRaw = document.createElementNS(NS, 'rect');
          rectRaw.setAttribute('x', String(x));
          rectRaw.setAttribute('y', String(RAW_BASE - hRaw));
          rectRaw.setAttribute('width', String(barW));
          rectRaw.setAttribute('height', String(hRaw));
          rectRaw.setAttribute('class', 'bar bar-raw');
          rowRaw.appendChild(rectRaw);

          // Centered bar — signed
          const hCen = (centered[i] / cenAbsMax) * HALF_H;
          const rectCen = document.createElementNS(NS, 'rect');
          rectCen.setAttribute('x', String(x));
          rectCen.setAttribute('y', String(hCen >= 0 ? CENTER_BASE - hCen : CENTER_BASE));
          rectCen.setAttribute('width', String(barW));
          rectCen.setAttribute('height', String(Math.abs(hCen)));
          rectCen.setAttribute('class', `bar ${hCen >= 0 ? 'bar-pos' : 'bar-neg'}`);
          rowCen.appendChild(rectCen);

          // Advantage bar — signed
          const hAdv = (advs[i] / advAbsMax) * HALF_H;
          const rectAdv = document.createElementNS(NS, 'rect');
          rectAdv.setAttribute('x', String(x));
          rectAdv.setAttribute('y', String(hAdv >= 0 ? ADV_BASE - hAdv : ADV_BASE));
          rectAdv.setAttribute('width', String(barW));
          rectAdv.setAttribute('height', String(Math.abs(hAdv)));
          rectAdv.setAttribute('class', `bar ${hAdv >= 0 ? 'bar-pos' : 'bar-neg'}`);
          rowAdv.appendChild(rectAdv);
        }
      }

      inputN.addEventListener('input', render);
      inputS.addEventListener('input', render);
      btn.addEventListener('click', () => {
        seed = (Math.random() * 0xffffffff) >>> 0;
        render();
      });

      render();
    });
  })();
</script>

<style>
  .grpo-figure {
    margin: 2.5rem auto;
    max-width: 880px;
  }

  .grpo-svg {
    width: 100%;
    height: auto;
    font-family: var(--font-sans);
  }

  .row-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16px;
    fill: var(--text);
  }
  .row-label .sub {
    font-size: 11px;
    font-style: normal;
  }

  .baseline {
    stroke: var(--border-strong);
    stroke-width: 1;
  }

  /* :global(): these rects are created dynamically via JS, so they don't get the
     data-astro-cid attribute that scoped selectors target. Scope by parent class. */
  .grpo-figure :global(.bar) {
    transition: fill 120ms ease;
  }
  .grpo-figure :global(.bar-raw) {
    fill: var(--text);
    opacity: 0.78;
  }
  .grpo-figure :global(.bar-pos) {
    fill: var(--accent);
    opacity: 0.85;
  }
  .grpo-figure :global(.bar-neg) {
    fill: #b85c5c;
    opacity: 0.85;
  }
  @media (prefers-color-scheme: dark) {
    .grpo-figure :global(.bar-neg) {
      fill: #e09494;
    }
  }

  .stat-readout {
    font-family: var(--font-mono);
    font-size: 12px;
    fill: var(--text-muted);
  }

  .grpo-formula {
    margin-top: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--code-bg);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    display: grid;
    gap: 0.4rem;
  }
  .grpo-formula .formula-note {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .grpo-controls {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 1.5rem;
    align-items: end;
    margin-top: 1.1rem;
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .grpo-controls { grid-template-columns: 1fr; gap: 0.75rem; }
  }

  .grpo-slider {
    display: grid;
    grid-template-columns: max-content 1fr max-content;
    column-gap: 0.6rem;
    align-items: center;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .grpo-slider .slider-label {
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
    font-weight: 600;
  }
  .grpo-slider input[type="range"] {
    width: 100%;
    accent-color: var(--accent);
  }
  .grpo-slider output {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text);
    min-width: 2.5rem;
    text-align: right;
  }

  .grpo-resample {
    font-family: var(--font-sans);
    font-size: 0.82rem;
    padding: 0.5rem 0.9rem;
    background: var(--bg-elevated);
    color: var(--text);
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    cursor: pointer;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .grpo-resample:hover {
    background: var(--code-bg);
    border-color: var(--accent);
  }
</style>
