---
// Viz — Async staleness distribution. Slider for sync vs one-step vs fully
// async. Show histogram of staleness across samples.
---

<figure class="ast-figure" aria-label="Async staleness distribution">
  <div class="ast-tabs" role="tablist">
    <button type="button" role="tab" class="ast-tab active" data-mode="sync"      aria-selected="true">synchronous</button>
    <button type="button" role="tab" class="ast-tab"        data-mode="one-step"  aria-selected="false">one-step-off</button>
    <button type="button" role="tab" class="ast-tab"        data-mode="full"      aria-selected="false">fully async</button>
  </div>

  <svg viewBox="0 0 720 260" class="ast-svg" preserveAspectRatio="xMidYMid meet" role="img">
    <g data-region="bars"></g>
    <line x1="60" y1="200" x2="700" y2="200" class="ast-axis" />
    <text x="380" y="230" class="ast-axis-label" text-anchor="middle">policy staleness (steps)</text>
  </svg>

  <div class="ast-readouts">
    <div class="ast-stat"><span class="ast-label">mean staleness</span><strong data-readout="mean">—</strong></div>
    <div class="ast-stat"><span class="ast-label">max staleness</span><strong data-readout="max">—</strong></div>
    <div class="ast-stat"><span class="ast-label">tokens clipped</span><strong data-readout="clipped">—</strong></div>
  </div>

  <div class="ast-callout"><p data-region="callout"></p></div>

  <figcaption>
    Histogram of the policy-version staleness across samples in a training batch. Sync has all
    samples from the current policy (0 staleness). One-step-off has all samples 1 step stale.
    Fully async has variable staleness from 1 to 5+ steps. The clip rate scales with staleness.
  </figcaption>
</figure>

<script>
  (function () {
    const NS = 'http://www.w3.org/2000/svg';
    function el(tag: string, attrs: Record<string, string | number>, parent: Element) {
      const e = document.createElementNS(NS, tag);
      for (const k in attrs) e.setAttribute(k, String(attrs[k]));
      parent.appendChild(e);
      return e;
    }

    const SPECS = {
      sync:     { dist: [100, 0, 0, 0, 0, 0], mean: 0, max: 0, clipped: 2, callout: 'Fully synchronous. Every sample was generated by the current policy. The IS ratio is 1.0 except where the policy has moved within the PPO inner loop (still bounded by clip ε).' },
      'one-step': { dist: [0, 100, 0, 0, 0, 0], mean: 1, max: 1, clipped: 8, callout: 'One-step-off. Every sample is from exactly 1 policy update ago. The IS ratio drifts proportionally to one step of training. Clipping handles it; ~8% of tokens hit the clip.' },
      full:     { dist: [15, 35, 28, 14, 6, 2], mean: 1.7, max: 5, clipped: 18, callout: 'Fully async. Variable staleness — some samples are fresh, some are 5 steps old. The IS clip kicks in more often (~18% of tokens), but you maintain higher GPU utilization across both pools.' },
    } as const;

    document.querySelectorAll<HTMLElement>('.ast-figure').forEach((fig) => {
      const barsG = fig.querySelector<SVGGElement>('[data-region="bars"]')!;
      const meanEl = fig.querySelector<HTMLElement>('[data-readout="mean"]')!;
      const maxEl = fig.querySelector<HTMLElement>('[data-readout="max"]')!;
      const clippedEl = fig.querySelector<HTMLElement>('[data-readout="clipped"]')!;
      const calloutEl = fig.querySelector<HTMLElement>('[data-region="callout"]')!;
      const tabs = Array.from(fig.querySelectorAll<HTMLButtonElement>('.ast-tab'));

      function render(mode: keyof typeof SPECS) {
        const s = SPECS[mode];
        barsG.replaceChildren();

        const X_START = 100;
        const X_END = 680;
        const N_BINS = 6;
        const BAR_GAP = 10;
        const BAR_W = (X_END - X_START - (N_BINS - 1) * BAR_GAP) / N_BINS;
        const Y_BASE = 200;
        const Y_TOP = 30;
        const MAX_H = Y_BASE - Y_TOP;

        s.dist.forEach((v, i) => {
          const x = X_START + i * (BAR_W + BAR_GAP);
          const h = (v / 100) * MAX_H;
          el('rect', { x, y: Y_BASE - h, width: BAR_W, height: h, class: 'ast-bar' }, barsG);
          el('text', { x: x + BAR_W/2, y: Y_BASE + 16, class: 'ast-tick', 'text-anchor': 'middle' }, barsG).textContent = String(i);
          if (v > 3) el('text', { x: x + BAR_W/2, y: Y_BASE - h - 4, class: 'ast-bar-value', 'text-anchor': 'middle' }, barsG).textContent = `${v}%`;
        });

        meanEl.textContent = s.mean.toFixed(1) + ' steps';
        maxEl.textContent = s.max + ' steps';
        clippedEl.textContent = s.clipped + '%';
        calloutEl.textContent = s.callout;
      }

      tabs.forEach((t) => {
        t.addEventListener('click', () => {
          tabs.forEach((tt) => {
            const active = tt === t;
            tt.classList.toggle('active', active);
            tt.setAttribute('aria-selected', String(active));
          });
          render(t.getAttribute('data-mode') as keyof typeof SPECS);
        });
      });
      render('sync');
    });
  })();
</script>

<style>
  .ast-figure { margin: 2.5rem 0; max-width: 880px; }
  .ast-tabs { display: flex; gap: 0.4rem; margin-bottom: 0.6rem; flex-wrap: wrap; }
  .ast-tab {
    font-family: var(--font-sans); font-size: 0.82rem; padding: 0.4rem 0.95rem;
    background: var(--bg-elevated); color: var(--text-muted);
    border: 1px solid var(--border-strong); border-radius: 4px; cursor: pointer;
  }
  .ast-tab.active { color: var(--bg); background: var(--accent); border-color: var(--accent); font-weight: 600; }
  .ast-svg {
    width: 100%; height: auto;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .ast-figure :global(.ast-bar) {
    fill: var(--accent);
    opacity: 0.85;
    transition: height 400ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ast-axis { stroke: var(--border-strong); stroke-width: 1; }
  .ast-axis-label { fill: var(--text-faint); font-size: 11px; font-family: var(--font-sans); }
  .ast-figure :global(.ast-tick) { fill: var(--text-muted); font-size: 11px; font-family: var(--font-mono); }
  .ast-figure :global(.ast-bar-value) { fill: var(--text); font-size: 10.5px; font-family: var(--font-mono); font-weight: 600; }
  .ast-readouts {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.6rem; margin-top: 0.85rem;
  }
  @media (max-width: 640px) { .ast-readouts { grid-template-columns: 1fr; } }
  .ast-stat {
    padding: 0.55rem 0.8rem; background: var(--code-bg); border-radius: 4px;
  }
  .ast-label {
    display: block;
    font-family: var(--font-sans); font-size: 0.7rem; color: var(--text-faint);
    text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.2rem;
  }
  .ast-stat strong { font-family: var(--font-mono); font-size: 0.92rem; color: var(--text); }
  .ast-callout {
    margin-top: 0.85rem;
    padding: 0.7rem 0.9rem;
    background: var(--code-bg);
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
  }
  .ast-callout p { margin: 0; font-family: var(--font-sans); font-size: 0.85rem; color: var(--text); line-height: 1.55; }
</style>
