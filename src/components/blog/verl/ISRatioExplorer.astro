---
// Viz — Importance sampling ratio explorer. For a token sequence, show ρ_t =
// exp(new_lp - old_lp) for each token. Slider for "policy drift" — the
// magnitude by which the new policy's log-probs differ from the old.
---

<figure class="is-figure" aria-label="Importance-sampling ratio explorer">
  <div class="is-controls">
    <label class="is-slider">
      <span class="is-control-label">policy drift</span>
      <input type="range" min="0" max="100" step="1" value="20" data-control="drift" />
      <output data-readout="drift">0.20</output>
    </label>
    <label class="is-slider">
      <span class="is-control-label">clip ε</span>
      <input type="range" min="5" max="40" step="1" value="20" data-control="epsilon" />
      <output data-readout="epsilon">0.20</output>
    </label>
    <button type="button" class="is-resample" data-control="resample">resample drift pattern</button>
  </div>

  <svg viewBox="0 0 720 280" class="is-svg" preserveAspectRatio="xMidYMid meet" role="img">
    <!-- Plot frame -->
    <rect x="60" y="30" width="640" height="200" class="is-frame" />

    <!-- The clip band shaded -->
    <rect class="is-band" data-region="band" />

    <!-- ρ = 1 line -->
    <line class="is-baseline" data-region="rho1" x1="60" x2="700" />

    <!-- Bars: one per token -->
    <g data-region="bars"></g>

    <!-- Y-axis labels -->
    <text x="50" y="38" class="is-tick-label" text-anchor="end" data-readout="ymax">2.0</text>
    <text x="50" y="234" class="is-tick-label" text-anchor="end">0.0</text>
    <text x="50" y="138" class="is-tick-label" text-anchor="end">1.0</text>

    <!-- X-axis label -->
    <text x="380" y="265" class="is-axis-label" text-anchor="middle">token position →</text>
  </svg>

  <div class="is-readouts">
    <div class="is-stat">
      <span class="is-control-label">tokens clipped</span>
      <strong data-readout="clipped">0 / 30</strong>
    </div>
    <div class="is-stat">
      <span class="is-control-label">mean ρ</span>
      <strong data-readout="mean">1.00</strong>
    </div>
    <div class="is-stat">
      <span class="is-control-label">max ρ</span>
      <strong data-readout="max">1.00</strong>
    </div>
  </div>

  <figcaption>
    Each bar is the IS ratio ρ_t = exp(new_lp − old_lp) for one token in a 30-token response.
    The shaded band is the PPO clip region [1−ε, 1+ε]. Bars outside the band are at risk of
    contributing high-variance gradients; the PPO objective clips them on the side that would
    improve the loss. Drag the drift slider to see what happens as the new policy diverges
    further from the rollout policy.
  </figcaption>
</figure>

<script>
  (function () {
    const NS = 'http://www.w3.org/2000/svg';
    function el(tag: string, attrs: Record<string, string | number>, parent: Element) {
      const e = document.createElementNS(NS, tag);
      for (const k in attrs) e.setAttribute(k, String(attrs[k]));
      parent.appendChild(e);
      return e;
    }

    const T = 30;
    const X_START = 60;
    const X_END = 700;
    const Y_TOP = 30;
    const Y_BOT = 230;
    const PLOT_W = X_END - X_START;
    const PLOT_H = Y_BOT - Y_TOP;
    const BAR_W = PLOT_W / T - 2;
    const STEP_X = PLOT_W / T;

    function mulberry32(seed: number) {
      return function () {
        let t = (seed += 0x6d2b79f5);
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    document.querySelectorAll<HTMLElement>('.is-figure').forEach((fig) => {
      const barsG = fig.querySelector<SVGGElement>('[data-region="bars"]')!;
      const bandRect = fig.querySelector<SVGRectElement>('[data-region="band"]')!;
      const rho1Line = fig.querySelector<SVGLineElement>('[data-region="rho1"]')!;
      const driftInput = fig.querySelector<HTMLInputElement>('[data-control="drift"]')!;
      const epsInput = fig.querySelector<HTMLInputElement>('[data-control="epsilon"]')!;
      const driftReadout = fig.querySelector<HTMLOutputElement>('[data-readout="drift"]')!;
      const epsReadout = fig.querySelector<HTMLOutputElement>('[data-readout="epsilon"]')!;
      const clippedReadout = fig.querySelector<HTMLElement>('[data-readout="clipped"]')!;
      const meanReadout = fig.querySelector<HTMLElement>('[data-readout="mean"]')!;
      const maxReadout = fig.querySelector<HTMLElement>('[data-readout="max"]')!;
      const yMaxReadout = fig.querySelector<HTMLElement>('[data-readout="ymax"]')!;
      const resampleBtn = fig.querySelector<HTMLButtonElement>('[data-control="resample"]')!;

      let seed = 42;
      // Each token gets a "drift direction" sampled from N(0,1)
      let directions: number[] = [];
      function resample() {
        const rng = mulberry32(seed);
        directions = [];
        for (let i = 0; i < T; i++) {
          // Box-Muller approx
          let u = 0, v = 0;
          while (u === 0) u = rng();
          while (v === 0) v = rng();
          const n = Math.sqrt(-2 * Math.log(u)) * Math.cos(2 * Math.PI * v);
          directions.push(n);
        }
      }
      resample();

      function yScale(rho: number, yMax: number) {
        const clamped = Math.max(0, Math.min(yMax, rho));
        return Y_BOT - (clamped / yMax) * PLOT_H;
      }

      function render() {
        const drift = parseInt(driftInput.value, 10) / 100;
        const eps = parseInt(epsInput.value, 10) / 100;
        driftReadout.value = drift.toFixed(2);
        epsReadout.value = eps.toFixed(2);

        const rhos = directions.map(d => Math.exp(d * drift));
        const rhoMax = Math.max(...rhos);
        const yMax = Math.max(2.0, Math.ceil(rhoMax * 2) / 2 + 0.1);
        yMaxReadout.textContent = yMax.toFixed(1);

        // Band: clip range
        const yHigh = yScale(1 + eps, yMax);
        const yLow = yScale(1 - eps, yMax);
        bandRect.setAttribute('x', String(X_START));
        bandRect.setAttribute('y', String(yHigh));
        bandRect.setAttribute('width', String(PLOT_W));
        bandRect.setAttribute('height', String(yLow - yHigh));

        // ρ = 1 baseline
        const y1 = yScale(1, yMax);
        rho1Line.setAttribute('y1', String(y1));
        rho1Line.setAttribute('y2', String(y1));

        // Bars
        barsG.replaceChildren();
        let clippedCount = 0;
        rhos.forEach((rho, i) => {
          const x = X_START + i * STEP_X + 1;
          const yTop = yScale(rho, yMax);
          const y = Math.min(yTop, y1);
          const h = Math.abs(yTop - y1);
          const inBand = rho >= (1 - eps) && rho <= (1 + eps);
          if (!inBand) clippedCount++;
          el('rect', {
            x, y, width: BAR_W, height: h,
            class: `is-bar ${inBand ? 'is-bar-in' : (rho > 1 ? 'is-bar-clip-high' : 'is-bar-clip-low')}`
          }, barsG);
        });

        const meanRho = rhos.reduce((a, b) => a + b, 0) / rhos.length;
        clippedReadout.textContent = `${clippedCount} / ${T}`;
        meanReadout.textContent = meanRho.toFixed(2);
        maxReadout.textContent = rhoMax.toFixed(2);
      }

      driftInput.addEventListener('input', render);
      epsInput.addEventListener('input', render);
      resampleBtn.addEventListener('click', () => {
        seed = Math.floor(Math.random() * 0xffffffff);
        resample();
        render();
      });

      render();
    });
  })();
</script>

<style>
  .is-figure {
    margin: 2.5rem 0;
    max-width: 880px;
  }
  .is-controls {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 1rem;
    align-items: center;
    margin-bottom: 0.6rem;
  }
  @media (max-width: 640px) {
    .is-controls { grid-template-columns: 1fr; }
  }
  .is-slider {
    display: grid;
    grid-template-columns: max-content 1fr max-content;
    gap: 0.55rem;
    align-items: center;
  }
  .is-control-label {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .is-slider input[type="range"] { accent-color: var(--accent); }
  .is-slider output {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text);
    min-width: 2.5rem;
    text-align: right;
  }
  .is-resample {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    padding: 0.4rem 0.85rem;
    background: var(--bg-elevated);
    color: var(--text);
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    cursor: pointer;
  }
  .is-resample:hover { background: var(--code-bg); border-color: var(--accent); }

  .is-svg {
    width: 100%;
    height: auto;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .is-frame {
    fill: none;
    stroke: var(--border-strong);
    stroke-width: 1;
  }
  .is-band {
    fill: var(--code-bg);
    opacity: 0.7;
  }
  .is-baseline {
    stroke: var(--text-muted);
    stroke-width: 1;
    stroke-dasharray: 3 3;
  }
  .is-tick-label {
    fill: var(--text-faint);
    font-size: 10px;
    font-family: var(--font-mono);
  }
  .is-axis-label {
    fill: var(--text-faint);
    font-size: 10px;
    font-family: var(--font-sans);
  }

  /* :global(): bars are dynamic */
  .is-figure :global(.is-bar-in) {
    fill: var(--accent);
    opacity: 0.8;
  }
  .is-figure :global(.is-bar-clip-high) {
    fill: #b85c5c;
    opacity: 0.85;
  }
  .is-figure :global(.is-bar-clip-low) {
    fill: #d08a3e;
    opacity: 0.85;
  }

  .is-readouts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
    margin-top: 0.8rem;
  }
  @media (max-width: 640px) {
    .is-readouts { grid-template-columns: 1fr; }
  }
  .is-stat {
    padding: 0.55rem 0.8rem;
    background: var(--code-bg);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .is-stat strong {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--text);
  }
</style>
