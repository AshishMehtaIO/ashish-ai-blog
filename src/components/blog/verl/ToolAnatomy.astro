---
// Viz — Tool anatomy. Highlight different parts of an annotated @function_tool example.
---

<figure class="ta-figure" aria-label="@function_tool anatomy">
  <div class="ta-stage">
    <pre class="ta-code"><code><span class="ta-line ta-h" data-part="decorator">@function_tool</span>
<span class="ta-line ta-h" data-part="signature">async def fetch_url(url: str, max_chars: int = 5000) -&gt; ToolResponse:</span>
<span class="ta-line ta-h" data-part="docstring">    """Fetch a URL and return its text content.</span>
<span class="ta-line ta-h" data-part="docstring">
    Args:
        url: The URL to fetch. Must be HTTPS.
        max_chars: Maximum characters to return. Defaults to 5000.
    """</span>
<span class="ta-line ta-h" data-part="body">    if not url.startswith("https://"):
        return ToolResponse(text="ERROR: Only HTTPS URLs allowed.")
    async with aiohttp.ClientSession() as session:
        async with session.get(url, timeout=10) as resp:
            content = await resp.text()</span>
<span class="ta-line ta-h" data-part="return">            return ToolResponse(text=content[:max_chars])</span>
</code></pre>

    <div class="ta-detail" data-region="detail">
      <h5 data-readout="title">Hover or click any part</h5>
      <p data-readout="desc">Each part of the function plays a specific role in registering and using the tool.</p>
    </div>
  </div>

  <figcaption>
    Anatomy of a <code>@function_tool</code>-decorated function. The decorator infers the
    OpenAI tool schema from the signature and docstring. <code>ToolResponse</code> wraps the
    output for re-injection into the conversation.
  </figcaption>
</figure>

<script>
  (function () {
    const PARTS: Record<string, { title: string; desc: string }> = {
      decorator: { title: '@function_tool decorator', desc: 'Registers the function with VERL\'s tool registry. Inspects the rest of the function definition to build the JSON schema the model will see.' },
      signature: { title: 'Type-hinted signature', desc: 'Parameter names and types map to schema fields. Defaults make a parameter optional. The return type ToolResponse tells the framework how to inject the result.' },
      docstring: { title: 'Google-style docstring', desc: 'The one-line summary becomes the tool description. The Args: block provides per-parameter descriptions. The model reads these to decide when and how to call the tool.' },
      body: { title: 'The actual implementation', desc: 'Plain async Python. Use aiohttp, asyncio.subprocess, or any async I/O. CPU-bound work runs concurrently across agent loops; I/O-bound work yields to the scheduler.' },
      return: { title: 'ToolResponse wrapper', desc: 'Wrap text, image, or video content. The framework appends ToolResponse contents to the conversation as a "tool" message for the next agent turn to see.' },
    };

    document.querySelectorAll<HTMLElement>('.ta-figure').forEach((fig) => {
      const lines = Array.from(fig.querySelectorAll<HTMLElement>('.ta-line'));
      const titleEl = fig.querySelector<HTMLElement>('[data-readout="title"]')!;
      const descEl = fig.querySelector<HTMLElement>('[data-readout="desc"]')!;

      function highlight(part: string) {
        lines.forEach((l) => l.classList.toggle('is-active', l.getAttribute('data-part') === part));
        const p = PARTS[part];
        if (p) {
          titleEl.textContent = p.title;
          descEl.textContent = p.desc;
        }
      }

      lines.forEach((l) => {
        l.addEventListener('click', () => highlight(l.getAttribute('data-part') || ''));
        l.addEventListener('mouseenter', () => highlight(l.getAttribute('data-part') || ''));
      });
    });
  })();
</script>

<style>
  .ta-figure { margin: 2.5rem 0; max-width: 880px; }
  .ta-stage {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 1rem;
  }
  @media (max-width: 700px) {
    .ta-stage { grid-template-columns: 1fr; }
  }
  .ta-code {
    margin: 0;
    padding: 0.85rem 1rem;
    background: var(--code-bg);
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.55;
    color: var(--text);
    overflow-x: auto;
    white-space: pre;
  }
  .ta-line {
    cursor: pointer;
    display: inline;
    padding: 0.05rem 0;
    border-radius: 2px;
    transition: background 200ms ease;
  }
  .ta-line.is-active {
    background: var(--accent);
    color: var(--bg);
    padding: 0.1rem 0.2rem;
  }
  .ta-line:hover { background: var(--bg-elevated); }
  .ta-detail {
    padding: 0.85rem 1rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
  }
  .ta-detail h5 {
    margin: 0 0 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
  }
  .ta-detail p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.55;
  }
</style>
