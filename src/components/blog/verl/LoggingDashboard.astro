---
// Viz — Mock W&B-style dashboard. Tiles with metrics; click a tile to see
// what to look for.
---

<figure class="ld-figure" aria-label="Logging dashboard">
  <div class="ld-grid">
    <div class="ld-tile" data-metric="reward">
      <span class="ld-metric-name">reward / mean</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 25 L 10 22 L 20 19 L 30 16 L 40 13 L 50 11 L 60 9 L 70 8 L 80 7 L 90 6.5 L 100 6" stroke="#4a8a3d" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">0.73</span>
    </div>
    <div class="ld-tile" data-metric="kl">
      <span class="ld-metric-name">policy / kl_to_ref</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 26 L 10 24 L 20 21 L 30 18 L 40 16 L 50 15 L 60 14 L 70 14 L 80 14 L 90 14 L 100 14" stroke="#4a78c2" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">0.13</span>
    </div>
    <div class="ld-tile" data-metric="adv">
      <span class="ld-metric-name">advantage / std</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 12 L 10 14 L 20 15 L 30 15 L 40 14 L 50 15 L 60 14 L 70 15 L 80 14 L 90 15 L 100 14" stroke="#6b4ab8" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">1.04</span>
    </div>
    <div class="ld-tile" data-metric="grad">
      <span class="ld-metric-name">actor / grad_norm</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 4 L 10 8 L 20 12 L 30 14 L 40 16 L 50 17 L 60 18 L 70 18 L 80 19 L 90 19 L 100 20" stroke="#d08a3e" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">1.84</span>
    </div>
    <div class="ld-tile" data-metric="clip">
      <span class="ld-metric-name">actor / clip_fraction</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 18 L 10 17 L 20 17 L 30 18 L 40 17 L 50 18 L 60 17 L 70 18 L 80 17 L 90 18 L 100 17" stroke="#b85c5c" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">9.8%</span>
    </div>
    <div class="ld-tile" data-metric="length">
      <span class="ld-metric-name">rollout / response_length</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 16 L 10 16 L 20 17 L 30 16 L 40 15 L 50 15 L 60 14 L 70 14 L 80 14 L 90 13 L 100 13" stroke="#8a8a8a" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">487</span>
    </div>
    <div class="ld-tile" data-metric="eval">
      <span class="ld-metric-name">eval / reward</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 26 L 12 22 L 25 18 L 38 15 L 50 12 L 62 10 L 75 9 L 88 8 L 100 7" stroke="#4a8a3d" stroke-dasharray="3 2" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">0.69</span>
    </div>
    <div class="ld-tile" data-metric="rollout-time">
      <span class="ld-metric-name">timing / rollout_seconds</span>
      <svg class="ld-spark" viewBox="0 0 100 30" preserveAspectRatio="none"><path d="M 0 14 L 10 15 L 20 13 L 30 14 L 40 14 L 50 13 L 60 14 L 70 13 L 80 14 L 90 13 L 100 14" stroke="#6cabc7" fill="none" stroke-width="1.5" /></svg>
      <span class="ld-metric-value">12.4s</span>
    </div>
  </div>

  <div class="ld-detail" data-region="detail">
    <h5 data-readout="title">Click any tile</h5>
    <p data-readout="desc">Each metric is a window into what the training run is doing right now. Hover or click for what to look for.</p>
  </div>

  <figcaption>
    A mock W&amp;B dashboard for a healthy training run. Sparklines show the trajectory of each
    metric. Click any tile to see what shape you want to see, what shape indicates trouble, and
    why each metric matters.
  </figcaption>
</figure>

<script>
  (function () {
    const METRICS: Record<string, { title: string; desc: string }> = {
      reward: { title: 'reward / mean — the headline metric', desc: 'Smoothly climbing curve, slowing as the policy saturates. Should climb past the SFT baseline within ~10% of total training steps. Flat lines mean the algorithm isn\'t learning; sharp spikes mean reward hacking.' },
      kl: { title: 'policy / kl_to_ref — the safety rail', desc: 'Gradual climb to a plateau set by your KL coefficient or adaptive controller target. Healthy plateau is usually 0.05 - 0.3. Sustained zero means β is too high (no learning); divergence to >1 means β too low (gibberish).' },
      adv: { title: 'advantage / std — variance health', desc: 'After normalization, advantages should have std ≈ 1.0. Drift indicates the advantage estimator is misbehaving (numerical issue, reward distribution shift, group degeneracy in GRPO).' },
      grad: { title: 'actor / grad_norm — stability indicator', desc: 'Slow decay over training is healthy. Spikes correlate with bad updates. If it oscillates wildly, enable gradient clipping. If it goes to zero, you\'ve stopped learning.' },
      clip: { title: 'actor / clip_fraction — trust region pressure', desc: 'Fraction of tokens where PPO clip activated. Healthy: 5-15%. Too low (<2%): your trust region is wider than needed; try larger ε. Too high (>30%): policy is drifting fast — slow down (smaller lr, more ppo_epochs).' },
      length: { title: 'rollout / response_length — distribution shift', desc: 'Watch for unprompted length explosion (length exploitation) or collapse (mode collapse). For long-form reasoning tasks, a gentle upward trend is fine; sudden jumps are suspicious.' },
      eval: { title: 'eval / reward — the truth check', desc: 'Should track training reward closely with a small constant gap. Divergence (training keeps rising, eval plateaus or drops) is the canonical reward-hacking signature.' },
      'rollout-time': { title: 'timing / rollout_seconds — the bottleneck check', desc: 'Stable rollout time is good. Slow increase over training can indicate longer responses (more compute per rollout). Sudden spikes indicate hung tools or slow external services.' },
    };

    document.querySelectorAll<HTMLElement>('.ld-figure').forEach((fig) => {
      const tiles = Array.from(fig.querySelectorAll<HTMLElement>('.ld-tile'));
      const titleEl = fig.querySelector<HTMLElement>('[data-readout="title"]')!;
      const descEl = fig.querySelector<HTMLElement>('[data-readout="desc"]')!;

      function highlight(metric: string) {
        tiles.forEach((t) => t.classList.toggle('is-active', t.getAttribute('data-metric') === metric));
        const m = METRICS[metric];
        if (m) {
          titleEl.textContent = m.title;
          descEl.textContent = m.desc;
        }
      }

      tiles.forEach((t) => {
        t.addEventListener('click', () => highlight(t.getAttribute('data-metric') || ''));
        t.addEventListener('mouseenter', () => highlight(t.getAttribute('data-metric') || ''));
      });
    });
  })();
</script>

<style>
  .ld-figure { margin: 2.5rem 0; max-width: 880px; }
  .ld-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    padding: 0.85rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  @media (max-width: 700px) { .ld-grid { grid-template-columns: repeat(2, 1fr); } }
  .ld-tile {
    padding: 0.55rem 0.7rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: all 200ms ease;
    display: grid;
    gap: 0.2rem;
  }
  .ld-tile:hover, .ld-tile.is-active {
    border-color: var(--accent);
    background: var(--code-bg);
  }
  .ld-metric-name {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .ld-spark {
    width: 100%;
    height: 24px;
    display: block;
  }
  .ld-metric-value {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 600;
  }
  .ld-detail {
    margin-top: 0.85rem;
    padding: 0.85rem 1rem;
    background: var(--code-bg);
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
  }
  .ld-detail h5 {
    margin: 0 0 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--accent);
  }
  .ld-detail p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.55;
  }
</style>
