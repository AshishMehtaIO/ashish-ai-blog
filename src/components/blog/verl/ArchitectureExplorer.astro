---
// Viz 3 — Architecture explorer. Click any block to see its responsibilities,
// signature, and file path in the side panel. Hover edges to see what DataProto
// fields flow along them.
//
// Pattern: hand-authored SVG + per-figure script, vanilla JS.
---

<figure class="arch-figure" aria-label="Interactive VERL architecture diagram">
  <div class="arch-shell">
    <svg
      viewBox="0 0 720 460"
      role="img"
      preserveAspectRatio="xMidYMid meet"
      class="arch-svg"
    >
      <defs>
        <marker id="arch-arrowhead" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
          <path d="M 0 0 L 10 5 L 0 10 z" />
        </marker>
      </defs>

      <!-- Layer labels (left side) -->
      <text class="layer-label" x="14" y="50">DRIVER</text>
      <text class="layer-label" x="14" y="200">WORKERS</text>
      <text class="layer-label" x="14" y="370">BACKENDS</text>

      <!-- Driver block -->
      <g class="block" data-block="driver" tabindex="0" role="button">
        <rect x="260" y="22" width="200" height="56" rx="8" />
        <text class="block-title" x="360" y="46">RayPPOTrainer</text>
        <text class="block-sub"   x="360" y="64">single-controller driver</text>
      </g>

      <!-- Resource pool container -->
      <g class="pool">
        <rect x="40" y="120" width="640" height="170" rx="10" class="pool-rect" />
        <text class="pool-label" x="60" y="142">ResourcePool</text>

        <!-- Worker blocks inside the pool -->
        <g class="block" data-block="actor-rollout-ref" tabindex="0" role="button">
          <rect x="60" y="158" width="200" height="110" rx="8" />
          <text class="block-title" x="160" y="186">ActorRolloutRef</text>
          <text class="block-sub"   x="160" y="206">colocated triad</text>
          <text class="block-sub"   x="160" y="226">generate · logprob</text>
          <text class="block-sub"   x="160" y="246">KL reference</text>
        </g>

        <g class="block" data-block="critic" tabindex="0" role="button">
          <rect x="280" y="158" width="160" height="110" rx="8" />
          <text class="block-title" x="360" y="186">Critic</text>
          <text class="block-sub"   x="360" y="206">value function</text>
          <text class="block-sub"   x="360" y="226">PPO only</text>
        </g>

        <g class="block" data-block="reward-model" tabindex="0" role="button">
          <rect x="460" y="158" width="200" height="110" rx="8" />
          <text class="block-title" x="560" y="186">RewardModel</text>
          <text class="block-sub"   x="560" y="206">optional</text>
          <text class="block-sub"   x="560" y="226">discriminative or</text>
          <text class="block-sub"   x="560" y="246">generative</text>
        </g>
      </g>

      <!-- Backends row -->
      <g class="block" data-block="training-backend" tabindex="0" role="button">
        <rect x="80" y="340" width="260" height="80" rx="8" />
        <text class="block-title" x="210" y="368">Training backend</text>
        <text class="block-sub"   x="210" y="390">FSDP · Megatron-LM</text>
      </g>

      <g class="block" data-block="rollout-backend" tabindex="0" role="button">
        <rect x="380" y="340" width="260" height="80" rx="8" />
        <text class="block-title" x="510" y="368">Rollout backend</text>
        <text class="block-sub"   x="510" y="390">vLLM · SGLang · HF</text>
      </g>

      <!-- Dispatch / collect arrows: driver → workers -->
      <g class="edges">
        <path class="edge" data-edge="d-arr"    d="M 320 78 L 160 158" marker-end="url(#arch-arrowhead)" />
        <path class="edge" data-edge="d-critic" d="M 360 78 L 360 158" marker-end="url(#arch-arrowhead)" />
        <path class="edge" data-edge="d-rm"     d="M 400 78 L 560 158" marker-end="url(#arch-arrowhead)" />

        <!-- Workers → backends -->
        <path class="edge" data-edge="arr-train" d="M 130 268 L 170 340" marker-end="url(#arch-arrowhead)" />
        <path class="edge" data-edge="arr-roll"  d="M 200 268 L 460 340" marker-end="url(#arch-arrowhead)" />
        <path class="edge" data-edge="cr-train"  d="M 320 268 L 250 340" marker-end="url(#arch-arrowhead)" />
        <path class="edge" data-edge="rm-train"  d="M 540 268 L 320 340" marker-end="url(#arch-arrowhead)" />
      </g>
    </svg>

    <aside class="arch-panel" data-open="false">
      <div class="arch-panel-empty">
        <p>Click any block to see what it does, what method it exposes, and where it lives in the repo.</p>
      </div>

      <article class="arch-panel-detail" hidden>
        <h4 class="panel-title" data-field="title"></h4>
        <p class="panel-desc" data-field="desc"></p>
        <dl class="panel-meta">
          <dt>Responsibilities</dt>
          <dd data-field="resp"></dd>
          <dt>Key methods</dt>
          <dd><code data-field="methods"></code></dd>
          <dt>Source</dt>
          <dd><a data-field="srcLink" target="_blank" rel="noopener noreferrer"></a></dd>
        </dl>
      </article>
    </aside>
  </div>
  <figcaption>
    VERL's runtime topology. The driver dispatches work to worker groups; workers
    delegate the actual compute to their attached backends. Click to explore.
  </figcaption>
</figure>

<script>
  (function () {
    type Detail = {
      title: string;
      desc: string;
      resp: string;
      methods: string;
      srcLink: string;
      srcLabel: string;
    };

    const details: Record<string, Detail> = {
      'driver': {
        title: 'RayPPOTrainer',
        desc: 'The single-controller driver. Runs on one process, owns the worker groups, and contains the orchestration logic for the entire training loop.',
        resp: 'Sample prompts → trigger rollout → trigger reward → compute advantages → call actor + critic updates → repeat.',
        methods: 'fit() · _validate() · _balance_batch()',
        srcLink: 'https://github.com/verl-project/verl/blob/main/verl/trainer/ppo/ray_trainer.py',
        srcLabel: 'verl/trainer/ppo/ray_trainer.py',
      },
      'actor-rollout-ref': {
        title: 'ActorRolloutRefWorker',
        desc: 'The colocated triad. Three logical roles — generating responses (rollout), computing log-probs and taking gradient steps (actor), holding the frozen reference model for the KL term — sharing GPUs and weights.',
        resp: 'Generate response tokens · compute new and old log-probs · compute reference log-probs for KL · run actor optimizer step.',
        methods: 'generate_sequences() · compute_log_prob() · compute_ref_log_prob() · update_actor()',
        srcLink: 'https://github.com/verl-project/verl/tree/main/verl/workers',
        srcLabel: 'verl/workers/',
      },
      'critic': {
        title: 'CriticWorker',
        desc: 'The value function for PPO. Optional — GRPO, RLOO, REINFORCE++, and DAPO skip the critic entirely. When present, it produces per-token value estimates used by GAE to compute advantages.',
        resp: 'Compute per-token values · run critic optimizer step.',
        methods: 'compute_values() · update_critic()',
        srcLink: 'https://github.com/verl-project/verl/tree/main/verl/workers',
        srcLabel: 'verl/workers/',
      },
      'reward-model': {
        title: 'RewardModelWorker',
        desc: 'A learned reward model, used when a rule-based scorer is not enough. Discriminative (classifier) or generative (LLM-as-judge). Lives behind an HTTP router so it can be scaled independently of training.',
        resp: 'Score generated responses · produce token-level or response-level reward signals.',
        methods: 'compute_rm_score()',
        srcLink: 'https://github.com/verl-project/verl/tree/main/verl/workers/reward_manager',
        srcLabel: 'verl/workers/reward_manager/',
      },
      'training-backend': {
        title: 'Training backend',
        desc: 'The engine that actually does training compute. FSDP (built into PyTorch) shards parameters, gradients, and optimizer state across data-parallel ranks. Megatron-LM combines tensor, pipeline, and data parallelism for very large models or clusters.',
        resp: 'Forward · backward · optimizer step under a sharded parameter layout.',
        methods: 'fsdp_train_step() · megatron_train_step()',
        srcLink: 'https://github.com/verl-project/verl/tree/main/verl/workers/sharding_manager',
        srcLabel: 'verl/workers/sharding_manager/',
      },
      'rollout-backend': {
        title: 'Rollout backend',
        desc: 'The engine that generates responses. vLLM is the default — paged KV cache, continuous batching. SGLang is a newer alternative with RadixAttention, structured generation, and a native async server. Hugging Face is supported as a debug fallback.',
        resp: 'Autoregressive decode with batched generation and KV-cache management.',
        methods: 'generate_sequences() (per-backend implementations)',
        srcLink: 'https://github.com/verl-project/verl/tree/main/verl/workers/rollout',
        srcLabel: 'verl/workers/rollout/',
      },
    };

    document.querySelectorAll<HTMLElement>('.arch-figure').forEach((fig) => {
      const blocks = fig.querySelectorAll<SVGGElement>('.block');
      const panel = fig.querySelector<HTMLElement>('.arch-panel');
      const emptyEl = fig.querySelector<HTMLElement>('.arch-panel-empty');
      const detailEl = fig.querySelector<HTMLElement>('.arch-panel-detail');
      if (!panel || !emptyEl || !detailEl) return;

      const show = (key: string) => {
        const d = details[key];
        if (!d) return;
        blocks.forEach((b) => b.classList.toggle('selected', b.getAttribute('data-block') === key));
        emptyEl.hidden = true;
        detailEl.hidden = false;
        panel.setAttribute('data-open', 'true');
        const set = (field: string, value: string) => {
          detailEl.querySelectorAll<HTMLElement>(`[data-field="${field}"]`).forEach((el) => {
            el.textContent = value;
          });
        };
        set('title', d.title);
        set('desc', d.desc);
        set('resp', d.resp);
        set('methods', d.methods);
        const link = detailEl.querySelector<HTMLAnchorElement>('a[data-field="srcLink"]');
        if (link) {
          link.href = d.srcLink;
          link.textContent = d.srcLabel;
        }
      };

      blocks.forEach((b) => {
        const key = b.getAttribute('data-block') || '';
        const handle = (e: Event) => {
          e.preventDefault();
          show(key);
        };
        b.addEventListener('click', handle);
        b.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') handle(e);
        });
      });
    });
  })();
</script>

<style>
  .arch-figure {
    margin: 2.5rem auto;
    max-width: 940px;
  }

  .arch-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  @media (max-width: 880px) {
    .arch-shell { grid-template-columns: 1fr; }
  }

  .arch-svg {
    width: 100%;
    height: auto;
    font-family: var(--font-sans);
  }

  .layer-label {
    font-family: var(--font-sans);
    font-size: 10px;
    fill: var(--text-faint);
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .pool-rect {
    fill: transparent;
    stroke: var(--border);
    stroke-width: 1;
    stroke-dasharray: 4 4;
  }
  .pool-label {
    font-family: var(--font-sans);
    font-size: 11px;
    fill: var(--text-faint);
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  /* Blocks (driver, workers, backends) */
  .block { cursor: pointer; outline: none; }
  .block rect {
    fill: var(--bg-elevated);
    stroke: var(--border-strong);
    stroke-width: 1.25;
    transition: fill 180ms ease, stroke 180ms ease, stroke-width 180ms ease;
  }
  .block:hover rect,
  .block:focus rect {
    fill: var(--code-bg);
    stroke: var(--accent);
  }
  .block.selected rect {
    fill: var(--code-bg);
    stroke: var(--accent);
    stroke-width: 2;
  }
  .block-title {
    font-family: var(--font-serif);
    font-size: 15px;
    font-weight: 600;
    text-anchor: middle;
    fill: var(--text);
    pointer-events: none;
  }
  .block-sub {
    font-size: 11.5px;
    text-anchor: middle;
    fill: var(--text-muted);
    pointer-events: none;
  }

  /* Edges */
  .edge {
    fill: none;
    stroke: var(--border-strong);
    stroke-width: 1.2;
    opacity: 0.65;
  }
  #arch-arrowhead path {
    fill: var(--border-strong);
  }

  /* Side panel */
  .arch-panel {
    border-left: 1px solid var(--border);
    padding: 0.5rem 0 0.5rem 1.25rem;
    min-height: 200px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  @media (max-width: 880px) {
    .arch-panel {
      border-left: none;
      border-top: 1px solid var(--border);
      padding: 1.25rem 0 0;
    }
  }

  .arch-panel-empty p {
    color: var(--text-faint);
    font-style: italic;
    margin: 0;
  }

  .panel-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.35rem;
  }
  .panel-desc {
    margin: 0 0 1rem;
    line-height: 1.55;
  }
  .panel-meta {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    column-gap: 1rem;
    row-gap: 0.55rem;
    font-size: 0.85rem;
  }
  .panel-meta dt {
    font-weight: 600;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.7rem;
    padding-top: 0.2rem;
  }
  .panel-meta dd {
    margin: 0;
    color: var(--text);
  }
  .panel-meta code {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    background: var(--code-bg);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .panel-meta a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    word-break: break-all;
  }
</style>
