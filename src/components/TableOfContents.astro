---
// Renders a left-side TOC from markdown headings
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{toc.length > 0 && (
  <nav class="toc" aria-label="Table of contents">
    <h2 class="toc-title">Contents</h2>
    <ol>
      {toc.map((h) => (
        <li class:list={[`depth-${h.depth}`]}>
          <a href={`#${h.slug}`}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
  }

  .toc-title {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-faint);
    margin: 0 0 0.75rem;
    font-weight: 600;
  }

  .toc ol {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc li {
    margin: 0.35rem 0;
  }

  .toc li.depth-3 {
    padding-left: 1rem;
  }

  .toc a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc a:hover {
    color: var(--accent);
  }
</style>
