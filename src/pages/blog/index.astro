---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { url } from '../../utils/url';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Writing — Ashish">
  <section class="archive">
    <header class="archive-header">
      <h1>Writing</h1>
      <p>Long-form notes, in reverse chronological order.</p>
    </header>

    <ol class="post-list">
      {posts.map((post) => (
        <li>
          <a href={url(`blog/${post.id}`)} class="post-link">
            <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
            <span class="post-title">{post.data.title}</span>
          </a>
          {post.data.description && <p class="post-desc">{post.data.description}</p>}
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>

<style>
  .archive {
    max-width: var(--content-width-wide);
    margin: 5rem auto;
    padding: 0 1.5rem;
  }

  .archive-header {
    margin-bottom: 3rem;
  }

  .archive-header h1 {
    margin: 0 0 0.5rem;
    font-size: 2.25rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .archive-header p {
    color: var(--text-muted);
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: baseline;
    text-decoration: none;
    color: var(--text);
  }

  .post-link time {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--text-faint);
  }

  .post-link .post-title {
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .post-link:hover .post-title {
    color: var(--accent);
  }

  .post-desc {
    margin: 0.65rem 0 0;
    margin-left: calc(11rem + 1.5rem);
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 700px) {
    .post-link {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }
    .post-desc {
      margin-left: 0;
    }
  }
</style>
